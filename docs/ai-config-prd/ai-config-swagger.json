{
  "swagger": "2.0",
  "info": {
    "title": "Nightingale AI Config API",
    "description": "AI Agent、LLM、Skill、MCP Server 配置管理接口",
    "version": "1.0.0"
  },
  "basePath": "/",
  "schemes": ["http", "https"],
  "consumes": ["application/json"],
  "produces": ["application/json"],
  "securityDefinitions": {
    "auth": {
      "type": "apiKey",
      "name": "Authorization",
      "in": "header"
    }
  },
  "security": [{"auth": []}],
  "tags": [
    {"name": "AI Agent", "description": "AI Agent 管理"},
    {"name": "AI LLM Config", "description": "LLM 大语言模型配置管理"},
    {"name": "AI Skill", "description": "Skill 技能管理"},
    {"name": "AI Skill File", "description": "Skill 资源文件管理"},
    {"name": "MCP Server", "description": "MCP Server 管理"},
    {"name": "AI Conversation", "description": "AI 对话管理"},
    {"name": "AI Chat", "description": "AI 对话（SSE 流式）"}
  ],
  "paths": {
    "/api/n9e/ai-agents": {
      "get": {
        "tags": ["AI Agent"],
        "summary": "获取所有 Agent 列表",
        "responses": {
          "200": {
            "description": "成功",
            "schema": {
              "type": "object",
              "properties": {
                "dat": {
                  "type": "array",
                  "items": {"$ref": "#/definitions/AIAgent"}
                },
                "err": {"type": "string"}
              }
            }
          }
        }
      },
      "post": {
        "tags": ["AI Agent"],
        "summary": "新增 Agent",
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {"$ref": "#/definitions/AIAgentCreate"}
          }
        ],
        "responses": {
          "200": {
            "description": "成功，返回新建 ID",
            "schema": {
              "type": "object",
              "properties": {
                "dat": {"type": "integer", "format": "int64"},
                "err": {"type": "string"}
              }
            }
          }
        }
      }
    },
    "/api/n9e/ai-agent/{id}": {
      "put": {
        "tags": ["AI Agent"],
        "summary": "更新指定 Agent",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "type": "integer",
            "format": "int64"
          },
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {"$ref": "#/definitions/AIAgentCreate"}
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "schema": {"$ref": "#/definitions/MessageResponse"}
          },
          "404": {"description": "Agent 不存在"}
        }
      },
      "delete": {
        "tags": ["AI Agent"],
        "summary": "删除指定 Agent",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "type": "integer",
            "format": "int64"
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "schema": {"$ref": "#/definitions/MessageResponse"}
          },
          "404": {"description": "Agent 不存在"}
        }
      }
    },
    "/api/n9e/ai-agent/{id}/test": {
      "post": {
        "tags": ["AI Agent"],
        "summary": "测试 Agent 的 LLM 连接",
        "description": "加载 Agent 关联的 LLM 配置并发送测试请求，验证连接是否正常",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "type": "integer",
            "format": "int64"
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "schema": {
              "type": "object",
              "properties": {
                "dat": {"$ref": "#/definitions/TestResult"},
                "err": {"type": "string"}
              }
            }
          },
          "404": {"description": "Agent 或关联的 LLM 配置不存在"}
        }
      }
    },
    "/api/n9e/ai-llm-configs": {
      "get": {
        "tags": ["AI LLM Config"],
        "summary": "获取所有 LLM 配置列表",
        "responses": {
          "200": {
            "description": "成功",
            "schema": {
              "type": "object",
              "properties": {
                "dat": {
                  "type": "array",
                  "items": {"$ref": "#/definitions/AILLMConfig"}
                },
                "err": {"type": "string"}
              }
            }
          }
        }
      },
      "post": {
        "tags": ["AI LLM Config"],
        "summary": "新增 LLM 配置",
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {"$ref": "#/definitions/AILLMConfigCreate"}
          }
        ],
        "responses": {
          "200": {
            "description": "成功，返回新建 ID",
            "schema": {
              "type": "object",
              "properties": {
                "dat": {"type": "integer", "format": "int64"},
                "err": {"type": "string"}
              }
            }
          }
        }
      }
    },
    "/api/n9e/ai-llm-config/{id}": {
      "put": {
        "tags": ["AI LLM Config"],
        "summary": "更新指定 LLM 配置",
        "description": "如果 api_key 为空，则保留原值",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "type": "integer",
            "format": "int64"
          },
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {"$ref": "#/definitions/AILLMConfigCreate"}
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "schema": {"$ref": "#/definitions/MessageResponse"}
          },
          "404": {"description": "LLM 配置不存在"}
        }
      },
      "delete": {
        "tags": ["AI LLM Config"],
        "summary": "删除指定 LLM 配置",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "type": "integer",
            "format": "int64"
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "schema": {"$ref": "#/definitions/MessageResponse"}
          },
          "404": {"description": "LLM 配置不存在"}
        }
      }
    },
    "/api/n9e/ai-llm-config/test": {
      "post": {
        "tags": ["AI LLM Config"],
        "summary": "测试 LLM 连接",
        "description": "传入完整的 LLM 配置进行连接测试。测试时会使用 extra_config 中的 timeout、TLS、proxy、custom_headers 设置。",
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["api_type", "api_url", "api_key", "model"],
              "properties": {
                "api_type": {"type": "string", "description": "提供商类型：openai / claude / gemini"},
                "api_url": {"type": "string", "description": "API 端点 URL"},
                "api_key": {"type": "string", "description": "API 密钥"},
                "model": {"type": "string", "description": "模型名称"},
                "extra_config": {"$ref": "#/definitions/LLMExtraConfig"}
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "schema": {
              "type": "object",
              "properties": {
                "dat": {"$ref": "#/definitions/TestResult"},
                "err": {"type": "string"}
              }
            }
          },
          "400": {"description": "缺少必填字段"}
        }
      }
    },
    "/api/n9e/ai-skills": {
      "get": {
        "tags": ["AI Skill"],
        "summary": "获取所有 Skill 列表",
        "parameters": [
          {
            "in": "query",
            "name": "search",
            "type": "string",
            "description": "按名称或描述模糊搜索"
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "schema": {
              "type": "object",
              "properties": {
                "dat": {
                  "type": "array",
                  "items": {"$ref": "#/definitions/AISkill"}
                },
                "err": {"type": "string"}
              }
            }
          }
        }
      },
      "post": {
        "tags": ["AI Skill"],
        "summary": "新增 Skill",
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {"$ref": "#/definitions/AISkillCreate"}
          }
        ],
        "responses": {
          "200": {
            "description": "成功，返回新建 ID",
            "schema": {
              "type": "object",
              "properties": {
                "dat": {"type": "integer", "format": "int64"},
                "err": {"type": "string"}
              }
            }
          }
        }
      }
    },
    "/api/n9e/ai-skill/{id}": {
      "get": {
        "tags": ["AI Skill"],
        "summary": "获取单个 Skill 详情",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "type": "integer",
            "format": "int64"
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "schema": {
              "type": "object",
              "properties": {
                "dat": {"$ref": "#/definitions/AISkill"},
                "err": {"type": "string"}
              }
            }
          },
          "404": {"description": "Skill 不存在"}
        }
      },
      "put": {
        "tags": ["AI Skill"],
        "summary": "更新指定 Skill",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "type": "integer",
            "format": "int64"
          },
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {"$ref": "#/definitions/AISkillCreate"}
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "schema": {"$ref": "#/definitions/MessageResponse"}
          },
          "404": {"description": "Skill 不存在"}
        }
      },
      "delete": {
        "tags": ["AI Skill"],
        "summary": "删除指定 Skill",
        "description": "级联删除关联的所有资源文件",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "type": "integer",
            "format": "int64"
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "schema": {"$ref": "#/definitions/MessageResponse"}
          },
          "404": {"description": "Skill 不存在"}
        }
      }
    },
    "/api/n9e/ai-skills/import": {
      "post": {
        "tags": ["AI Skill"],
        "summary": "导入 Skill 文件",
        "description": "上传 .md 文件导入 Skill。支持 YAML frontmatter（name/description），文件内容作为 instructions。无 frontmatter 时文件名作为 name，全部内容作为 instructions。",
        "consumes": ["multipart/form-data"],
        "parameters": [
          {
            "in": "formData",
            "name": "file",
            "type": "file",
            "required": true,
            "description": "仅支持 .md 格式"
          }
        ],
        "responses": {
          "200": {
            "description": "成功，返回新建 Skill ID",
            "schema": {
              "type": "object",
              "properties": {
                "dat": {"type": "integer", "format": "int64"},
                "err": {"type": "string"}
              }
            }
          },
          "400": {"description": "文件格式不支持"}
        }
      }
    },
    "/api/n9e/ai-skill/{id}/files": {
      "get": {
        "tags": ["AI Skill File"],
        "summary": "获取 Skill 的资源文件列表",
        "description": "返回文件元数据（不含 content）",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "type": "integer",
            "format": "int64",
            "description": "Skill ID"
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "schema": {
              "type": "object",
              "properties": {
                "dat": {
                  "type": "array",
                  "items": {"$ref": "#/definitions/AISkillFileMeta"}
                },
                "err": {"type": "string"}
              }
            }
          }
        }
      },
      "post": {
        "tags": ["AI Skill File"],
        "summary": "上传资源文件",
        "consumes": ["multipart/form-data"],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "type": "integer",
            "format": "int64",
            "description": "Skill ID"
          },
          {
            "in": "formData",
            "name": "file",
            "type": "file",
            "required": true,
            "description": "支持 .md / .txt / .json / .yaml / .yml / .csv，最大 2MB，每个 Skill 最多 20 个文件"
          }
        ],
        "responses": {
          "200": {
            "description": "成功，返回新建文件 ID",
            "schema": {
              "type": "object",
              "properties": {
                "dat": {"type": "integer", "format": "int64"},
                "err": {"type": "string"}
              }
            }
          },
          "400": {"description": "文件格式不支持或超过大小限制"},
          "404": {"description": "Skill 不存在"}
        }
      }
    },
    "/api/n9e/ai-skill-file/{fileId}": {
      "get": {
        "tags": ["AI Skill File"],
        "summary": "获取资源文件内容",
        "parameters": [
          {
            "in": "path",
            "name": "fileId",
            "required": true,
            "type": "integer",
            "format": "int64"
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "schema": {
              "type": "object",
              "properties": {
                "dat": {"$ref": "#/definitions/AISkillFile"},
                "err": {"type": "string"}
              }
            }
          },
          "404": {"description": "文件不存在"}
        }
      },
      "delete": {
        "tags": ["AI Skill File"],
        "summary": "删除资源文件",
        "parameters": [
          {
            "in": "path",
            "name": "fileId",
            "required": true,
            "type": "integer",
            "format": "int64"
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "schema": {"$ref": "#/definitions/MessageResponse"}
          },
          "404": {"description": "文件不存在"}
        }
      }
    },
    "/api/n9e/mcp-servers": {
      "get": {
        "tags": ["MCP Server"],
        "summary": "获取所有 MCP Server 列表",
        "responses": {
          "200": {
            "description": "成功",
            "schema": {
              "type": "object",
              "properties": {
                "dat": {
                  "type": "array",
                  "items": {"$ref": "#/definitions/MCPServer"}
                },
                "err": {"type": "string"}
              }
            }
          }
        }
      },
      "post": {
        "tags": ["MCP Server"],
        "summary": "新增 MCP Server",
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {"$ref": "#/definitions/MCPServerCreate"}
          }
        ],
        "responses": {
          "200": {
            "description": "成功，返回新建 ID",
            "schema": {
              "type": "object",
              "properties": {
                "dat": {"type": "integer", "format": "int64"},
                "err": {"type": "string"}
              }
            }
          }
        }
      }
    },
    "/api/n9e/mcp-server/{id}": {
      "put": {
        "tags": ["MCP Server"],
        "summary": "更新指定 MCP Server",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "type": "integer",
            "format": "int64"
          },
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {"$ref": "#/definitions/MCPServerCreate"}
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "schema": {"$ref": "#/definitions/MessageResponse"}
          },
          "404": {"description": "MCP Server 不存在"}
        }
      },
      "delete": {
        "tags": ["MCP Server"],
        "summary": "删除指定 MCP Server",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "type": "integer",
            "format": "int64"
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "schema": {"$ref": "#/definitions/MessageResponse"}
          },
          "404": {"description": "MCP Server 不存在"}
        }
      }
    },
    "/api/n9e/mcp-server/test": {
      "post": {
        "tags": ["MCP Server"],
        "summary": "测试 MCP Server 连接",
        "description": "传入具体的 url 和 headers 配置进行测试，初始化 MCP 会话并获取工具列表",
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["url"],
              "properties": {
                "url": {"type": "string", "description": "MCP Server 远程地址"},
                "headers": {
                  "type": "object",
                  "additionalProperties": {"type": "string"},
                  "description": "自定义 HTTP Headers"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "schema": {
              "type": "object",
              "properties": {
                "dat": {"$ref": "#/definitions/MCPTestResult"},
                "err": {"type": "string"}
              }
            }
          },
          "400": {"description": "url 为空"}
        }
      }
    },
    "/api/n9e/mcp-server/{id}/tools": {
      "get": {
        "tags": ["MCP Server"],
        "summary": "获取 MCP Server 提供的工具列表",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "type": "integer",
            "format": "int64"
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "schema": {
              "type": "object",
              "properties": {
                "dat": {
                  "type": "array",
                  "items": {"$ref": "#/definitions/MCPTool"}
                },
                "err": {"type": "string"}
              }
            }
          },
          "404": {"description": "MCP Server 不存在"}
        }
      }
    },
    "/api/n9e/ai-conversations": {
      "get": {
        "tags": ["AI Conversation"],
        "summary": "获取当前用户的对话列表",
        "description": "按 updated_at 降序排列",
        "responses": {
          "200": {
            "description": "成功",
            "schema": {
              "type": "object",
              "properties": {
                "dat": {
                  "type": "array",
                  "items": {"$ref": "#/definitions/AIConversation"}
                },
                "err": {"type": "string"}
              }
            }
          }
        }
      },
      "post": {
        "tags": ["AI Conversation"],
        "summary": "新建对话",
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "title": {"type": "string"},
                "context": {"type": "string", "description": "JSON 字符串，页面上下文"}
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功，返回新建的对话对象",
            "schema": {
              "type": "object",
              "properties": {
                "dat": {"$ref": "#/definitions/AIConversation"},
                "err": {"type": "string"}
              }
            }
          }
        }
      }
    },
    "/api/n9e/ai-conversation/{id}": {
      "get": {
        "tags": ["AI Conversation"],
        "summary": "获取对话详情（含消息列表）",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "type": "integer",
            "format": "int64"
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "schema": {
              "type": "object",
              "properties": {
                "dat": {
                  "type": "object",
                  "properties": {
                    "conversation": {"$ref": "#/definitions/AIConversation"},
                    "messages": {
                      "type": "array",
                      "items": {"$ref": "#/definitions/AIConversationMessage"}
                    }
                  }
                },
                "err": {"type": "string"}
              }
            }
          },
          "403": {"description": "无权访问此对话"},
          "404": {"description": "对话不存在"}
        }
      },
      "put": {
        "tags": ["AI Conversation"],
        "summary": "更新对话标题",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "type": "integer",
            "format": "int64"
          },
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "title": {"type": "string"}
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "schema": {"$ref": "#/definitions/MessageResponse"}
          },
          "403": {"description": "无权访问此对话"},
          "404": {"description": "对话不存在"}
        }
      },
      "delete": {
        "tags": ["AI Conversation"],
        "summary": "删除对话",
        "description": "级联删除所有关联消息",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "type": "integer",
            "format": "int64"
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "schema": {"$ref": "#/definitions/MessageResponse"}
          },
          "403": {"description": "无权访问此对话"},
          "404": {"description": "对话不存在"}
        }
      }
    },
    "/api/n9e/ai-conversation/{id}/messages": {
      "post": {
        "tags": ["AI Conversation"],
        "summary": "批量添加对话消息",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "type": "integer",
            "format": "int64",
            "description": "对话 ID"
          },
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "type": "array",
              "items": {"$ref": "#/definitions/AIConversationMessageCreate"}
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "schema": {"$ref": "#/definitions/MessageResponse"}
          },
          "403": {"description": "无权访问此对话"},
          "404": {"description": "对话不存在"}
        }
      }
    },
    "/api/n9e/ai-chat": {
      "post": {
        "tags": ["AI Chat"],
        "summary": "AI 对话（SSE 流式响应）",
        "description": "根据 action_key 分发到不同的处理逻辑。响应为 text/event-stream 格式。事件类型：chunk（流式内容）、done（完成）、error（错误）。",
        "produces": ["text/event-stream"],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {"$ref": "#/definitions/AIChatRequest"}
          }
        ],
        "responses": {
          "200": {
            "description": "SSE 流式响应",
            "schema": {
              "type": "string",
              "description": "text/event-stream，每个事件格式: event: <type>\\ndata: <json>\\n\\n"
            }
          },
          "400": {"description": "参数错误"},
          "503": {"description": "AI Agent 未启用"}
        }
      }
    }
